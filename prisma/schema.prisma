generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  student
  staff
  admin
}

enum CourseLevel {
  Beginner
  Intermediate
  Advanced
}

enum EnrollmentStatus {
  active
  completed
  pending
}

enum AssignmentStatus {
  pending
  submitted
  graded
}

enum CertificateStatus {
  valid
  revoked
}

enum PaymentStatus {
  pending
  confirmed
  failed
}

enum GalleryCategory {
  trainings
  workshops
  events
  graduation
  conferences
}

enum GalleryType {
  image
  video
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String
  passwordHash  String    @map("password_hash")
  role          UserRole  @default(student)
  avatar        String?
  phone         String?
  refreshToken     String?   @map("refresh_token")
  resetToken       String?   @map("reset_token")
  resetTokenExp    DateTime? @map("reset_token_exp")
  twoFactorSecret  String?   @map("two_factor_secret")
  twoFactorEnabled Boolean   @default(false) @map("two_factor_enabled")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  enrollments   Enrollment[]
  payments      Payment[]
  certificates  Certificate[]
  assignments   Assignment[]
  staffProfile  StaffProfile?
  taughtCourses Course[]    @relation("instructor")

  @@map("users")
}

model StaffProfile {
  id       String   @id @default(uuid())
  userId   String   @unique @map("user_id")
  position String
  bio      String   @default("")
  photo    String   @default("")
  skills   String[] @default([])
  social   Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("staff_profiles")
}

model Course {
  id               String      @id @default(uuid())
  title            String
  description      String
  instructorId     String      @map("instructor_id")
  price            Float
  category         String
  level            CourseLevel
  duration         String
  image            String      @default("")
  curriculum       String[]    @default([])
  requirements     String[]    @default([])
  learningOutcomes String[]    @default([]) @map("learning_outcomes")
  enrolledStudents Int         @default(0) @map("enrolled_students")
  rating           Float       @default(0)
  isFeatured       Boolean     @default(false) @map("is_featured")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  instructor   User         @relation("instructor", fields: [instructorId], references: [id])
  enrollments  Enrollment[]
  payments     Payment[]
  certificates Certificate[]
  assignments  Assignment[]

  @@map("courses")
}

model Enrollment {
  id           String           @id @default(uuid())
  studentId    String           @map("student_id")
  courseId      String           @map("course_id")
  enrolledDate DateTime         @default(now()) @map("enrolled_date")
  progress     Int              @default(0)
  status       EnrollmentStatus @default(pending)
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  student User   @relation(fields: [studentId], references: [id])
  course  Course @relation(fields: [courseId], references: [id])

  @@unique([studentId, courseId])
  @@map("enrollments")
}

model Assignment {
  id            String           @id @default(uuid())
  studentId     String           @map("student_id")
  courseId       String           @map("course_id")
  title         String
  description   String           @default("")
  fileUrl       String?          @map("file_url")
  dueDate       DateTime?        @map("due_date")
  status        AssignmentStatus @default(pending)
  grade         Float?
  submittedDate DateTime?        @map("submitted_date")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  student User   @relation(fields: [studentId], references: [id])
  course  Course @relation(fields: [courseId], references: [id])

  @@map("assignments")
}

model Certificate {
  id                String            @id @default(uuid())
  studentId         String            @map("student_id")
  studentName       String            @map("student_name")
  courseId           String            @map("course_id")
  courseName        String            @map("course_name")
  issueDate         DateTime          @default(now()) @map("issue_date")
  certificateNumber String            @unique @map("certificate_number")
  status            CertificateStatus @default(valid)
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  student User   @relation(fields: [studentId], references: [id])
  course  Course @relation(fields: [courseId], references: [id])

  @@map("certificates")
}

model Payment {
  id            String        @id @default(uuid())
  studentId     String        @map("student_id")
  courseId       String        @map("course_id")
  amount        Float
  date          DateTime      @default(now())
  status        PaymentStatus @default(pending)
  method        String        @default("Bank Transfer")
  reference     String?       @unique
  paystackId    String?       @map("paystack_id")
  channel       String?
  currency      String        @default("NGN")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  student User   @relation(fields: [studentId], references: [id])
  course  Course @relation(fields: [courseId], references: [id])

  @@map("payments")
}

model BlogPost {
  id        String   @id @default(uuid())
  title     String
  content   String
  excerpt   String
  author    String
  date      DateTime @default(now())
  category  String
  image     String   @default("")
  tags      String[] @default([])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("blog_posts")
}

model GalleryItem {
  id        String          @id @default(uuid())
  title     String
  category  GalleryCategory
  type      GalleryType     @default(image)
  url       String
  thumbnail String?
  date      DateTime        @default(now())
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  @@map("gallery_items")
}
